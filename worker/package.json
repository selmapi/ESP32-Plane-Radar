{
  "name": "plane-radar-map-service",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker: ports scripts/build_region_map.py's OSM pipeline to TypeScript and serves binary region-map blobs to the ESP32 Plane Radar device (V3 Phase 1).",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.107.0"
  },
  "allowScripts": {
    "sharp@0.34.5": true,
    "workerd@1.20260701.1": true,
    "esbuild@0.28.1": true
  }
}
